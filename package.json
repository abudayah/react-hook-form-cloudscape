{
  "name": "react-hook-form-cloudscape",
  "version": "0.0.6",
  "description": "A React Hook Form wrapper designed for effortless integration of validations into Cloudscape forms and inputs",
  "license": "MIT",
  "main": "dist/index.js",
  "module": "dist/index.modern.js",
  "source": "src/index.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.modern.js",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "clean": "rm -rf dist node_modules build",
    "format": "prettier --write '**/*.{js,jsx,ts,tsx,json}'",
    "build": "npm run format && microbundle --no-compress --format modern,cjs --jsx React.createElement"
  },
  "peerDependencies": {
    "@cloudscape-design/components": "^3.0",
    "react": "^16.8 || ^17 || ^18",
    "react-dom": "^16.8 || ^17 || ^18",
    "react-hook-form": "7.36.0"
  },
  "devDependencies": {
    "@babel/core": "^7.24.5",
    "@babel/plugin-transform-runtime": "^7.24.3",
    "@babel/preset-typescript": "^7.24.1",
    "@babel/runtime": "^7.24.5",
    "@cloudscape-design/components": "^3.0.625",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.0",
    "babel-loader": "^9.1.3",
    "microbundle": "^0.15.1",
    "prettier": "^3.2.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "7.36.1",
    "typescript": "^5.4.5"
  },
  "npm-pretty-much": {
    "runRelease": "always",
    "runTest": "never"
  }
}
