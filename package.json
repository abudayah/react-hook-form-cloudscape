{
  "name": "react-hook-form-cloudscape",
  "version": "1.0.0",
  "license": "MIT",
  "description": "A React Hook Form wrapper designed for effortless integration of validations into Cloudscape forms and inputs",
  "repository": {
    "type": "git",
    "url": "https://github.com/abudayah/react-hook-form-cloudscape.git"
  },
  "keywords": [
    "react",
    "cloudscape",
    "react-hook-form"
  ],
  "type": "module",
  "source": "lib/index.ts",
  "main": "./dist/index.cjs",
  "module": "./dist/index.modern.js",
  "unpkg": "./dist/index.umd.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "types": "./dist/index.d.ts",
    "require": "./dist/index.cjs",
    "default": "./dist/index.modern.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "analyze": "microbundle --visualize --jsx",
    "build": "microbundle --jsx React.createElement",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0"
  },
  "peerDependencies": {
    "@cloudscape-design/components": "^3.0",
    "react": "^16.8 || ^17 || ^18",
    "react-dom": "^16.8 || ^17 || ^18",
    "react-hook-form": "^7.36"
  },
  "devDependencies": {
    "@hookform/resolvers": "^3.3.2",
    "@types/node": "^20.8.10",
    "@types/react": "^18.2.38",
    "@typescript-eslint/eslint-plugin": "^6.12.0",
    "eslint": "^8.54.0",
    "eslint-plugin-import": "^2.29.0",
    "eslint-plugin-n": "^16.3.1",
    "eslint-plugin-promise": "^6.1.1",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.4",
    "glob": "^10.3.10",
    "microbundle": "^0.15.1",
    "typescript": "^5.3.2",
    "yup": "^1.3.2"
  }
}
